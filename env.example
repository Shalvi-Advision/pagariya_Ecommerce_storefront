# Environment Configuration
NODE_ENV=production
REACT_APP_API_URL=https://fakestoreapi.com
REACT_APP_SITE_URL=https://ecomsetup.manchar.in

# API Configuration for Departments and Categories
REACT_APP_PROJECT_CODE=your_project_code_here
REACT_APP_STORE_CODE=your_store_code_here

# DirectAdmin Hosting Configuration
FTP_SERVER=your_directadmin_ftp_server_here
FTP_USERNAME=your_directadmin_username_here
FTP_PASSWORD=your_directadmin_password_here
REMOTE_DIR=/domains/ecomsetup.manchar.in/public_html/

# DirectAdmin SFTP Configuration (Alternative to FTP)
SFTP_SERVER=your_directadmin_sftp_server_here
SFTP_USERNAME=your_directadmin_username_here
SFTP_PASSWORD=your_directadmin_password_here

# Domain Configuration
REACT_APP_DOMAIN=ecomsetup.manchar.in
REACT_APP_HTTPS=true

# Analytics (Optional)
REACT_APP_GOOGLE_ANALYTICS_ID=your_ga_id_here
REACT_APP_HOTJAR_ID=your_hotjar_id_here

# Payment Gateway (When implemented)
REACT_APP_STRIPE_PUBLISHABLE_KEY=your_stripe_key_here
REACT_APP_PAYPAL_CLIENT_ID=your_paypal_id_here

# Email Service (When implemented)
REACT_APP_EMAILJS_SERVICE_ID=your_emailjs_service_id
REACT_APP_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
REACT_APP_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
